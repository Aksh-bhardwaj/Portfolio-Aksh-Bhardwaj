DEBUG=True

# Dev: optional if DEBUG=True (settings inject a dev-only fallback when unset).
# Prod: REQUIRED — generate a long random string; never commit.
SECRET_KEY=

# Prod (DEBUG=False): REQUIRED — comma-separated hosts, no spaces.
# Example: ALLOWED_HOSTS=my-api.up.railway.app,.onrender.com
ALLOWED_HOSTS=

# SQLite local default if DATABASE_URL unset:
# DATABASE_URL=

# Postgres (Railway / Neon / etc.):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# Inbox for contact form notifications (optional)
CONTACT_NOTIFY_EMAIL=

# Optional: skip IPv4 rewrite for Postgres (see settings.py)
# SKIP_DB_IPV4=1
