node_modules/
**/node_modules/
dist/
**/dist/
dist-ssr/
*.local

# Django / DB (local SQLite)
*.sqlite3
**/*.sqlite3
db.sqlite3

# Logs & OS
*.log
.DS_Store
Thumbs.db
.idea/
.vscode/
